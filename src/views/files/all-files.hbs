<div class="row">
    {{#each files}}
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                {{#if imageURL}}
                    <img src="{{imageURL}}" class="card-img-top file-card-img" alt="{{name}}" loading="lazy">
                {{else}}
                    <div class="card-img-top file-card-placeholder">
                        <span>Sin imagen</span>
                    </div>
                {{/if}}
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">{{name}}</h5>
                    {{#if empleo}}<p class="card-text text-muted mb-1">{{empleo}}</p>{{/if}}
                    {{#if raza}}<p class="card-text text-muted mb-3">{{raza}}</p>{{/if}}
                    <div class="mt-auto">
                        <a href="/files/edit/{{_id}}" class="btn btn-warning btn-block btn-sm">Editar</a>
                        <form action="/files/delete/{{_id}}?_method=DELETE" method="POST" class="mt-2">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-danger btn-block btn-sm">Eliminar</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    {{else}}
        <div class="col-12">
            <div class="card mx-auto text-center">
                <div class="card-body">
                    <h2 class="h4">Todavía no tenés fichas</h2>
                    <p class="text-muted mb-3">Creá tu primera ficha de personaje con imagen, historia y stats.</p>
                    <a href="/files/add" class="btn btn-success">Crear primera ficha</a>
                </div>
            </div>
        </div>
    {{/each}}
</div>
