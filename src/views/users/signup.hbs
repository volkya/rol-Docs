<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="card text-center">
            <div class="card-header"><h3 class="mb-0">Registrarse</h3></div>
            <div class="card-body">
                <form action="/users/signup" method="POST">
                    <div class="form-group text-left">
                        <label for="username">Nombre de usuario</label>
                        <input type="text" class="form-control" id="username" name="username" placeholder="Tu nombre de usuario" value="{{username}}" required>
                    </div>
                    <div class="form-group text-left">
                        <label for="email">Email</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="tu@email.com" value="{{email}}" required>
                    </div>
                    <div class="form-group text-left">
                        <label for="password">Contraseña</label>
                        <input type="password" class="form-control" id="password" name="password" placeholder="Mínimo 4 caracteres" required>
                    </div>
                    <div class="form-group text-left">
                        <label for="confirm_password">Confirmar contraseña</label>
                        <input type="password" class="form-control" id="confirm_password" name="confirm_password" placeholder="Repetí tu contraseña" required>
                    </div>
                    <button class="btn btn-primary btn-block" type="submit">
                        Crear cuenta
                    </button>
                </form>
                <p class="mt-3 mb-0">
                    ¿Ya tenés cuenta?
                    <a href="/users/signin">Iniciá sesión acá</a>
                </p>
            </div>
        </div>
    </div>
</div>
